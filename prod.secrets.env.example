# Production secrets for `wrangler secret bulk`.
# Copy to prod.secrets.env (gitignored), fill in the values, then:
#
#   bunx wrangler secret bulk prod.secrets.env && rm prod.secrets.env
#
# Local dev does NOT use this file — it reads .dev.vars instead.
# Non-sensitive config (APP_URL, MAIL_FROM, POLAR_SERVER, ids) stays in wrangler.jsonc vars.

# BetterAuth session signing. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The account with this email becomes the platform admin (/admin).
SUPERADMIN_EMAIL=you@example.com

# https://resend.com/api-keys (production key — RESEND_BASE_URL stays unset in prod)
RESEND_API_KEY=

# https://polar.sh → Settings → Access Tokens (sandbox.polar.sh while POLAR_SERVER=sandbox)
# Required scopes: checkouts:write, customer_sessions:write
POLAR_ACCESS_TOKEN=

# Polar → Webhooks → endpoint https://rdyrct.com/api/webhooks/polar
# Required events: subscription.active, subscription.revoked,
# subscription.canceled, subscription.uncanceled
# Copy the signing secret here.
POLAR_WEBHOOK_SECRET=

# dash.cloudflare.com → My Profile → API Tokens → custom token:
# permission Zone → SSL and Certificates → Edit, scoped to your zone (custom domains)
CF_API_TOKEN=

# Better Stack source → Data ingestion tab. Alerts fire when a storage message
# dead-letters (BETTERSTACK_INGEST_URL is a var, set in wrangler.jsonc).
BETTERSTACK_SOURCE_TOKEN=
